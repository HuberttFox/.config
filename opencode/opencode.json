  "enabled_providers": [
    "cliproxy"
  ],
  "model": "cliproxy/gpt-5.3-codex",
  "provider": {
    "cliproxy": {
      "models": {
        "gpt-5.2": {},
        "gpt-5.2-codex": {},
        "gpt-5.3-codex": {},
	"gpt-5.3-codex-low": {},
	"gpt-5.3-codex-medium": {},
	"gpt-5.3-codex-high": {},
	"gpt-5.3-codex-xhigh": {}, 
	"gpt-5.4-mini": {},
	"gpt-5.4": {},
	"gpt-5.4-low": {},
	"gpt-5.4-medium": {},
	"gpt-5.4-high": {},
	"gpt-5.4-xhigh": {},
	"deepseek-v4-flash": {},
	"deepseek-v4-pro": {}
      },
      "name": "CliProxy",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "apiKey": "{env:CLIPROXY_API_KEY}",
        "baseURL": "https://cliproxy-api.jenyu.cn/v1"
      }
    }
  },
  "small_model": "cliproxy/gpt-5.3-codex-spark"
}
