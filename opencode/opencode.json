{
  "$schema": "https://opencode.ai/config.json",
  "enabled_providers": [
    "cliproxy"
  ],
  "model": "cliproxy/gpt-5.3-codex",
  "provider": {
    "cliproxy": {
      "models": {
        "gpt-5.2": {},
        "gpt-5.2-codex": {},
        "gpt-5.3-codex": {},
        "gpt-5.3-codex-spark": {}
      },
      "name": "CliProxy",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "apiKey": "{env:CLIPROXY_API_KEY}",
        "baseURL": "https://cliproxy-api.jenyu.cn/v1"
      }
    }
  },
  "small_model": "cliproxy/gpt-5.3-codex-spark"
}